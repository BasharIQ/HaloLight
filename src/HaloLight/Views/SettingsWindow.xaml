<Window x:Class="HaloLight.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HaloLight"
        Icon="/Assets/AppIcon.ico"
        Width="480"
        Height="700"
        MinWidth="480"
        MinHeight="480"
        Background="#0a0c10"
        Foreground="#FFFFFF"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <!-- Premium color palette from Stitch design -->
        <SolidColorBrush x:Key="PrimaryAccent" Color="#3b82f6" />
        <SolidColorBrush x:Key="SecondaryAccent" Color="#06b6d4" />
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextSecondary" Color="#9ca3af" />
        <SolidColorBrush x:Key="TextMuted" Color="#6b7280" />
        <SolidColorBrush x:Key="CardBackground" Color="#14161c" />
        <SolidColorBrush x:Key="InsetBackground" Color="#10131a" />
        <SolidColorBrush x:Key="ModalBackdrop" Color="#B8141820" />
        <SolidColorBrush x:Key="BorderSubtle" Color="#272a33" />
        <SolidColorBrush x:Key="ButtonSurface" Color="#171b24" />
        <SolidColorBrush x:Key="ButtonSurfaceHover" Color="#1d2430" />
        <SolidColorBrush x:Key="ButtonSurfacePressed" Color="#111720" />
        <SolidColorBrush x:Key="ButtonBorderStrong" Color="#334155" />
        <SolidColorBrush x:Key="ComboBoxItemHover" Color="#1c2230" />
        <SolidColorBrush x:Key="ComboBoxItemSelected" Color="#24324a" />
        <SolidColorBrush x:Key="ScrollbarTrack" Color="#0f141d" />
        <SolidColorBrush x:Key="ScrollbarTrackBorder" Color="#1b2432" />
        
        <!-- Gradient brush for accent elements -->
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#3b82f6" Offset="0" />
            <GradientStop Color="#06b6d4" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentGradientHover" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#5b95f8" Offset="0" />
            <GradientStop Color="#22d3ee" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentGradientPressed" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#2563eb" Offset="0" />
            <GradientStop Color="#0891b2" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ScrollbarThumbBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#4b8ef8" Offset="0" />
            <GradientStop Color="#0ea5e9" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ScrollbarThumbBrushHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#69a6ff" Offset="0" />
            <GradientStop Color="#22d3ee" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ScrollbarThumbBrushPressed" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#2563eb" Offset="0" />
            <GradientStop Color="#0891b2" Offset="1" />
        </LinearGradientBrush>
        
        <!-- Glass card style matching Stitch design -->
        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="ScrollBarRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Margin="2"
                                CornerRadius="4"
                                Background="{StaticResource ScrollbarThumbBrush}"
                                BorderBrush="#66E0F2FE"
                                BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0"
                                                  BlurRadius="10"
                                                  Color="#0ea5e9"
                                                  Opacity="0.18" />
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ScrollbarThumbBrushHover}" />
                                <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="#99E0F2FE" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ScrollbarThumbBrushPressed}" />
                                <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="#AA7DD3FC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Width="{TemplateBinding Width}" SnapsToDevicePixels="True">
                <Border Margin="1,0,0,0"
                        Background="{StaticResource ScrollbarTrack}"
                        BorderBrush="{StaticResource ScrollbarTrackBorder}"
                        BorderThickness="1"
                        CornerRadius="6" />
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarRepeatButtonStyle}" Command="ScrollBar.PageUpCommand" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumbStyle}" MinHeight="36" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarRepeatButtonStyle}" Command="ScrollBar.PageDownCommand" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Height="{TemplateBinding Height}" SnapsToDevicePixels="True">
                <Border Margin="0,1,0,0"
                        Background="{StaticResource ScrollbarTrack}"
                        BorderBrush="{StaticResource ScrollbarTrackBorder}"
                        BorderThickness="1"
                        CornerRadius="6" />
                <Track x:Name="PART_Track">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarRepeatButtonStyle}" Command="ScrollBar.PageLeftCommand" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumbStyle}" MinWidth="36" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarRepeatButtonStyle}" Command="ScrollBar.PageRightCommand" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="12" />
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Margin" Value="0,8,0,0" />
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Section header style - uppercase labels -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
        
        <!-- Custom Slider Template with gradient track -->
        <Style x:Key="GradientSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="0,8,0,16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border x:Name="TrackBackground" 
                                    Height="4" 
                                    CornerRadius="2"
                                    Background="#272a33">
                                <Border x:Name="TrackFill" 
                                        HorizontalAlignment="Left"
                                        Height="4" 
                                        CornerRadius="2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#3b82f6" Offset="0" />
                                            <GradientStop Color="#06b6d4" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Focusable="False"
                                                  OverridesDefaultStyle="True"
                                                  Background="Transparent"
                                                  BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Focusable="False"
                                                  OverridesDefaultStyle="True"
                                                  Background="Transparent"
                                                  BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Ellipse Fill="White">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="0" 
                                                                          BlurRadius="8" 
                                                                          Color="#3b82f6" 
                                                                          Opacity="0.6"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TrackFill" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonSurface}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0"
                                                  BlurRadius="14"
                                                  Color="#000000"
                                                  Opacity="0.18" />
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ButtonSurfaceHover}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource ButtonBorderStrong}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ButtonSurfacePressed}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource PrimaryAccent}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentGradient}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#00000000"
                                BorderThickness="1"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0"
                                                  BlurRadius="18"
                                                  Color="#0ea5e9"
                                                  Opacity="0.28" />
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AccentGradientHover}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#66E0F2FE" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AccentGradientPressed}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#8822D3EE" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InsetBackground}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ColorSwatchButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SwatchBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="10" Color="#000000" Opacity="0.2" />
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwatchBorder" Property="BorderBrush" Value="{StaticResource TextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SwatchBorder" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Custom Toggle Switch Style -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="SwitchBorder" 
                                    Width="44" Height="24" 
                                    CornerRadius="12"
                                    Background="#272a33"
                                    BorderBrush="#3b82f6"
                                    BorderThickness="0">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="4" Color="#000000" Opacity="0.2"/>
                                </Border.Effect>
                                <Ellipse x:Name="SwitchThumb" 
                                         Width="18" Height="18" 
                                         Fill="White"
                                         HorizontalAlignment="Left"
                                         Margin="3,0,0,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="2" Color="#000000" Opacity="0.3"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                            <ContentPresenter x:Name="ContentPresenter" 
                                              Content="{TemplateBinding Content}"
                                              Margin="52,0,0,0"
                                              VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#3b82f6" Offset="0" />
                                            <GradientStop Color="#06b6d4" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource CardBackground}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ComboBoxItemHover}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ComboBoxItemSelected}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource CardBackground}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ComboToggle"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ToggleBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="36" />
                                                </Grid.ColumnDefinitions>

                                                <ContentPresenter Margin="12,8,0,8"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplateSelector="{Binding ItemTemplateSelector, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}" />

                                                <Border Grid.Column="1"
                                                        Background="{StaticResource InsetBackground}"
                                                        BorderBrush="{StaticResource BorderSubtle}"
                                                        BorderThickness="1,0,0,0"
                                                        CornerRadius="0,8,8,0">
                                                    <Path Width="10"
                                                          Height="6"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Data="M 0 0 L 5 6 L 10 0"
                                                          Stroke="{StaticResource TextSecondary}"
                                                          StrokeThickness="1.75"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          SnapsToDevicePixels="True" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource ComboBoxItemSelected}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource ComboBoxItemSelected}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Margin="0,6,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="{StaticResource CardBackground}"
                                        BorderBrush="{StaticResource BorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <ScrollViewer MaxHeight="220"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PART_Popup" Property="MinHeight" Value="36" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Margin="24,20,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel VerticalAlignment="Center">
                <TextBlock FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           Text="HaloLight" />
                <TextBlock Margin="0,4,0,0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource SecondaryAccent}">
                    <Hyperlink NavigateUri="https://github.com/BasharIQ"
                               RequestNavigate="GitHubLink_OnRequestNavigate"
                               Foreground="{StaticResource SecondaryAccent}">
                        <Run Text="By Bashar" />
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
            
            <Border Grid.Column="2"
                    Width="156"
                    Background="{StaticResource InsetBackground}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12">
                <StackPanel>
                    <TextBlock FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               Text="LIVE PREVIEW" />

                    <Grid Width="128"
                          Height="80"
                          Margin="0,10,0,8"
                          HorizontalAlignment="Center"
                          Opacity="{Binding LivePreviewFrameOpacity}">
                        <Border Background="#0c1017"
                                BorderBrush="#1b2432"
                                BorderThickness="1"
                                CornerRadius="20" />

                        <Border Margin="18,14"
                                Background="#111826"
                                CornerRadius="10" />

                        <Ellipse Width="42"
                                 Height="42"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Fill="{Binding SecondaryColorPreview}"
                                 Opacity="0.18">
                            <Ellipse.Effect>
                                <BlurEffect Radius="18" />
                            </Ellipse.Effect>
                        </Ellipse>

                        <Border Margin="9"
                                Background="Transparent"
                                BorderBrush="{Binding LivePreviewOuterBrush}"
                                BorderThickness="{Binding LivePreviewOuterBorderThickness}"
                                CornerRadius="16">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0"
                                                  BlurRadius="16"
                                                  Opacity="0.92"
                                                  Color="{Binding LivePreviewOuterGlowColor}" />
                            </Border.Effect>
                        </Border>

                        <Border Margin="18"
                                Background="Transparent"
                                BorderBrush="{Binding LivePreviewInnerBrush}"
                                BorderThickness="{Binding LivePreviewInnerBorderThickness}"
                                CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0"
                                                  BlurRadius="10"
                                                  Opacity="0.72"
                                                  Color="{Binding LivePreviewInnerGlowColor}" />
                            </Border.Effect>
                        </Border>
                    </Grid>

                    <TextBlock FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Text="{Binding LivePreviewStatusLabel}" />
                </StackPanel>
            </Border>
        </Grid>
        
        <ScrollViewer Grid.Row="1" 
                      Margin="24,24,24,24" 
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,12,0">
                <!-- Light Engine Section -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="LIGHT ENGINE" />
                <Border Style="{StaticResource GlassCardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Light enabled" />
                            <CheckBox Grid.Column="1" 
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      IsChecked="{Binding IsEnabled}" />
                        </Grid>
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   Text="{Binding HotkeyLabel}" />
                    </StackPanel>
                </Border>
                
                <!-- Tone and Intensity Section -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="TONE AND INTENSITY" Margin="0,8,0,12" />
                <Border Style="{StaticResource GlassCardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Brightness" Margin="0" />
                            <TextBlock Grid.Column="1" 
                                       Style="{StaticResource ValueStyle}"
                                       Text="{Binding Brightness, StringFormat={}{0:0}%}" />
                        </Grid>
                        <Slider Minimum="5" 
                                Maximum="100" 
                                Value="{Binding Brightness}" 
                                Style="{StaticResource GradientSliderStyle}" />
                        
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Color temperature" Margin="0" />
                            <TextBlock Grid.Column="1" 
                                       Style="{StaticResource ValueStyle}"
                                       Text="{Binding ColorTemperature, StringFormat={}{0:0}K}" />
                        </Grid>
                        <Slider Minimum="2700" 
                                Maximum="6500" 
                                Value="{Binding ColorTemperature}" 
                                Style="{StaticResource GradientSliderStyle}" />
                        
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Edge thickness" Margin="0" />
                            <TextBlock Grid.Column="1" 
                                       Style="{StaticResource ValueStyle}"
                                       Text="{Binding EdgeThickness, StringFormat={}{0:0}px}" />
                        </Grid>
                        <Slider Minimum="24" 
                                Maximum="260" 
                                Value="{Binding EdgeThickness}" 
                                Style="{StaticResource GradientSliderStyle}" />
                    </StackPanel>
                </Border>
                
                <!-- Accent Color Section -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="ACCENT COLOR" Margin="0,8,0,12" />
                <Border Style="{StaticResource GlassCardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <Border Width="36" 
                                    Height="36" 
                                    CornerRadius="18" 
                                    BorderBrush="{StaticResource BorderSubtle}" 
                                    BorderThickness="1"
                                    Background="{Binding SecondaryColorPreview}">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0" 
                                                     BlurRadius="8" 
                                                     Color="#3b82f6" 
                                                     Opacity="0.4"/>
                                </Border.Effect>
                            </Border>
                             <StackPanel Grid.Column="1" 
                                          Margin="12,0,12,0" 
                                          VerticalAlignment="Center">
                                 <TextBlock FontSize="13" 
                                            FontWeight="Medium" 
                                            Foreground="{StaticResource TextPrimary}"
                                            Text="Accent glow" />
                                  <TextBlock Margin="0,2,0,0"
                                             Foreground="{StaticResource TextPrimary}"
                                             FontSize="12"
                                             FontWeight="SemiBold"
                                             Text="{Binding SecondaryColorHex}" />
                              </StackPanel>
                              <Button Grid.Column="2" 
                                      Style="{StaticResource GlassButtonStyle}"
                                      Margin="0,0,8,0"
                                      Click="OpenSecondaryColorModal_OnClick"
                                      Content="Edit" />
                              <Button Grid.Column="3" 
                                      Style="{StaticResource GlassButtonStyle}"
                                      Click="SecondaryColorReset_OnClick"
                                      Content="Reset" />
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Device and Behavior Section -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="DEVICE AND BEHAVIOR" Margin="0,8,0,12" />
                <Border Style="{StaticResource GlassCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Monitor" Margin="0,0,0,8" />
                        <ComboBox Margin="0,0,0,16"
                                  ItemsSource="{Binding Displays}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="DeviceName"
                                  SelectedValue="{Binding SelectedMonitorDeviceName}" />
                        
                        <CheckBox Content="Launch at startup" 
                                  Foreground="{StaticResource TextSecondary}"
                                  IsChecked="{Binding LaunchAtStartup}" />
                        <CheckBox Margin="0,8,0,0" 
                                  Content="Exclude from screen capture" 
                                  Foreground="{StaticResource TextSecondary}"
                                  IsChecked="{Binding ExcludeFromCapture}" />
                    </StackPanel>
                </Border>
                
                <Button Height="44" 
                        Margin="0,8,0,8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="HideButton_OnClick"
                        Content="Hide to Tray" />
            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="SecondaryColorModal"
              Grid.RowSpan="2"
              Panel.ZIndex="20"
              Visibility="Collapsed"
              Background="{StaticResource ModalBackdrop}"
              MouseDown="SecondaryColorModalBackdrop_OnMouseDown">
            <Border Width="340"
                    MaxWidth="340"
                    Padding="18"
                    CornerRadius="16"
                    Background="{StaticResource CardBackground}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextPrimary}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="Accent glow" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Text="Tune the halo edge color with presets, RGB sliders, or a hex value." />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Margin="12,0,0,0"
                                Style="{StaticResource GlassButtonStyle}"
                                Click="CloseSecondaryColorModal_OnClick"
                                Content="Done" />
                    </Grid>

                    <Border Background="{StaticResource InsetBackground}"
                            BorderBrush="{StaticResource BorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Quick picks" Margin="0,0,0,10" />
                            <WrapPanel>
                                <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#29D7FF" Tag="#29D7FF" Click="SecondaryColorPreset_OnClick" ToolTip="Electric cyan" />
                                <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#60A5FA" Tag="#60A5FA" Click="SecondaryColorPreset_OnClick" ToolTip="Cool blue" />
                                <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#A78BFA" Tag="#A78BFA" Click="SecondaryColorPreset_OnClick" ToolTip="Soft violet" />
                                <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#F472B6" Tag="#F472B6" Click="SecondaryColorPreset_OnClick" ToolTip="Rose bloom" />
                                <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#F59E0B" Tag="#F59E0B" Click="SecondaryColorPreset_OnClick" ToolTip="Amber pop" />
                                <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#34D399" Tag="#34D399" Click="SecondaryColorPreset_OnClick" ToolTip="Mint glow" />
                            </WrapPanel>

                            <TextBlock Style="{StaticResource LabelStyle}" Text="Fine tune" Margin="0,10,0,8" />

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Background="#2b1114" CornerRadius="5" Padding="8,4">
                                    <TextBlock Text="R" Foreground="#FCA5A5" FontWeight="SemiBold" FontSize="11" />
                                </Border>
                                <Slider x:Name="SecondaryColorRedSlider"
                                        Grid.Column="1"
                                        Margin="12,0"
                                        Minimum="0"
                                        Maximum="255"
                                        ValueChanged="SecondaryColorChannel_OnValueChanged"
                                        Style="{StaticResource GradientSliderStyle}" />
                                <TextBlock Grid.Column="2"
                                           Width="28"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Foreground="{StaticResource TextSecondary}"
                                           Text="{Binding ElementName=SecondaryColorRedSlider, Path=Value, StringFormat={}{0:0}}" />
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Background="#122a18" CornerRadius="5" Padding="8,4">
                                    <TextBlock Text="G" Foreground="#86EFAC" FontWeight="SemiBold" FontSize="11" />
                                </Border>
                                <Slider x:Name="SecondaryColorGreenSlider"
                                        Grid.Column="1"
                                        Margin="12,0"
                                        Minimum="0"
                                        Maximum="255"
                                        ValueChanged="SecondaryColorChannel_OnValueChanged"
                                        Style="{StaticResource GradientSliderStyle}" />
                                <TextBlock Grid.Column="2"
                                           Width="28"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Foreground="{StaticResource TextSecondary}"
                                           Text="{Binding ElementName=SecondaryColorGreenSlider, Path=Value, StringFormat={}{0:0}}" />
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Background="#0f2334" CornerRadius="5" Padding="8,4">
                                    <TextBlock Text="B" Foreground="#7DD3FC" FontWeight="SemiBold" FontSize="11" />
                                </Border>
                                <Slider x:Name="SecondaryColorBlueSlider"
                                        Grid.Column="1"
                                        Margin="12,0"
                                        Minimum="0"
                                        Maximum="255"
                                        ValueChanged="SecondaryColorChannel_OnValueChanged"
                                        Style="{StaticResource GradientSliderStyle}" />
                                <TextBlock Grid.Column="2"
                                           Width="28"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Foreground="{StaticResource TextSecondary}"
                                           Text="{Binding ElementName=SecondaryColorBlueSlider, Path=Value, StringFormat={}{0:0}}" />
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SecondaryColorHexInput"
                                         Style="{StaticResource GlassTextBoxStyle}"
                                         MaxLength="7"
                                         VerticalAlignment="Center"
                                         KeyDown="SecondaryColorHexInput_OnKeyDown"
                                         Text="#29D7FF" />
                                <Button Grid.Column="1"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource GlassButtonStyle}"
                                        Click="SecondaryColorHexApply_OnClick"
                                        Content="Apply" />
                            </Grid>
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11"
                                       Text="Current accent:"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="{Binding SecondaryColorHex}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
